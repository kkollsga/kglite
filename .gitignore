# Skip specific directories
# `make bundle-bin` copies the release kglite-mcp-server binary here for
# dev-with-bin and the wheel-build workflow — build artifact, never committed.
/kglite/_bin/
/pytest/
/venv/
/.venv/
/.venv*/
/.claude/
# Codex conventions and skills are workstation-local adapters. CLAUDE.md is
# the tracked repository authority; do not auto-generate or stage these files.
/.agents/
/AGENTS.md
/.pytest_cache/
/data/
# Local dev working folder — see dev-docs/README.md for the canonical layout.
# Durable: `plans/` (actionable plans/backlog), `designs/` (design-decision
# reference), `bench/scripts/` + `bench/results/`, `todos.md`. Auto-purged by
# the dev-docs-cleanup skill: `temp/` (>1d, offload large output here to dodge
# the token gate), `bench/out/` (>14d, generated graphs/dumps), `bin/` (>7d,
# soft-deleted). Local working state, never committed.
/dev-docs/
# Inbox of feedback/coordination notes (`unread/` = needs action, `read/` =
# archive). Kept at the repo root by preference; local working state, never
# committed — see the "Inbox hygiene" section in CLAUDE.md.
/inbox/
# Competitive-library benchmarks. The public, OSS-only `graphsuite` (it powers
# the linkable BENCHMARKS.md table) IS tracked; the rest stays local —
# `largescale`, `embedded_app` carry private / heavy data. (`/dir/*` +
# `!/dir/sub/` so a subdir can be re-included.)
/benchmarks/competitive/*
!/benchmarks/competitive/graphsuite/
# but not graphsuite's local run artifacts
/benchmarks/competitive/graphsuite/__pycache__/

# Ignore Rust build artifacts (keep wheels for distribution)
/target/
!/target/wheels/

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Compiled extension modules (built by maturin develop)
*.so
*.pyd

# IDE and editor settings
.vscode/

# Performance baselines (dev artifacts)
/baselines/
/.benchmarks/

# Hypothesis database (property-based testing cache)
/.hypothesis/

# Coverage data
.coverage
coverage.xml
rust-core-coverage.lcov

# Generated graph files
*.kgl
# …except the small Cat G-N regression fixtures (5.9 KB total, byte-deterministic
# from tests/fixtures/build_fixtures.py with a seeded RNG). These are tracked
# in-repo so CI sees them; reproducible by re-running that script.
!tests/fixtures/*.kgl

# Sphinx docs build output
docs/_build/
docs/autoapi/

# macOS system files
.DS_Store
.bench-current.json
.perf_audit_*.json
