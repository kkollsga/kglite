{
  "nodes": {
    "Company": {
      "csv": "processed/company.csv",
      "pk": "cik",
      "title": "name",
      "properties": {
        "name": "string",
        "sic": "string",
        "sic_description": "string",
        "state_of_incorporation": "string",
        "fiscal_year_end": "string",
        "tickers": "string",
        "exchanges": "string",
        "entity_type": "string",
        "former_names": "string"
      },
      "connections": {
        "fk_edges": {
          "IN_INDUSTRY": { "target": "SicCode", "fk": "sic" }
        }
      }
    },

    "SicCode": {
      "csv": "processed/sic.csv",
      "pk": "sic",
      "title": "description",
      "properties": {
        "description": "string"
      }
    },

    "Person": {
      "csv": "processed/person.csv",
      "pk": "person_nid",
      "title": "display_name",
      "properties": {
        "display_name": "string",
        "cik": "string"
      }
    },

    "Security": {
      "csv": "processed/security.csv",
      "pk": "cusip",
      "title": "name",
      "properties": {
        "name": "string",
        "title_of_class": "string"
      }
    },

    "InstitutionalManager": {
      "csv": "processed/institutional_manager.csv",
      "pk": "manager_cik",
      "title": "name",
      "properties": {
        "name": "string"
      }
    },

    "Filing": {
      "csv": "processed/filing_index.csv",
      "pk": "accession_number",
      "title": "primary_document",
      "properties": {
        "cik": "string",
        "form_type": "string",
        "filed_date": "string",
        "report_date": "string",
        "primary_document": "string"
      },
      "connections": {
        "fk_edges": {
          "FILED_BY": { "target": "Company", "fk": "cik" }
        }
      }
    },

    "InsiderTransaction": {
      "csv": "processed/insider_transaction.csv",
      "pk": "transaction_nid",
      "title": "security_title",
      "properties": {
        "direction": "string",
        "security_title": "string",
        "transaction_date": "string",
        "transaction_code": "string",
        "shares": "float",
        "price_per_share": "float",
        "total_value": "float",
        "direct_indirect": "string",
        "is_derivative": "int"
      },
      "connections": {
        "fk_edges": {
          "BY_INSIDER": { "target": "Person", "fk": "person_nid" },
          "IN_COMPANY": { "target": "Company", "fk": "issuer_cik" },
          "REPORTED_IN": { "target": "Filing", "fk": "source_accession" }
        }
      }
    },

    "Holding": {
      "csv": "processed/holding.csv",
      "pk": "holding_nid",
      "title": "security_title",
      "properties": {
        "security_title": "string",
        "as_of_date": "string",
        "shares": "float",
        "percent_of_class": "float",
        "direct_indirect": "string",
        "is_derivative": "int"
      },
      "connections": {
        "fk_edges": {
          "OWNED_BY": { "target": "Person", "fk": "person_nid" },
          "IN_COMPANY": { "target": "Company", "fk": "issuer_cik" },
          "REPORTED_IN": { "target": "Filing", "fk": "source_accession" }
        }
      }
    },

    "InstitutionalHolding": {
      "csv": "processed/institutional_holding.csv",
      "pk": "institutional_holding_nid",
      "title": "name_of_issuer",
      "properties": {
        "name_of_issuer": "string",
        "title_of_class": "string",
        "figi": "string",
        "value": "float",
        "shares": "float",
        "shares_type": "string",
        "put_call": "string",
        "investment_discretion": "string",
        "voting_sole": "float",
        "voting_shared": "float",
        "voting_none": "float",
        "other_managers": "string",
        "quarter": "string"
      },
      "connections": {
        "fk_edges": {
          "OWNED_BY": { "target": "InstitutionalManager", "fk": "manager_cik" },
          "OF_SECURITY": { "target": "Security", "fk": "cusip" },
          "REPORTED_IN": { "target": "Filing", "fk": "source_accession" }
        }
      }
    },

    "Role": {
      "csv": "processed/role.csv",
      "pk": "role_nid",
      "title": "role_type",
      "properties": {
        "role_type": "string",
        "officer_title": "string",
        "since_date": "string"
      },
      "connections": {
        "fk_edges": {
          "OF_PERSON": { "target": "Person", "fk": "person_nid" },
          "AT_COMPANY": { "target": "Company", "fk": "issuer_cik" },
          "REPORTED_IN": { "target": "Filing", "fk": "source_accession" }
        }
      }
    },

    "CorporateEvent": {
      "csv": "processed/corporate_event.csv",
      "pk": "event_nid",
      "title": "description",
      "properties": {
        "item_code": "string",
        "description": "string",
        "event_date": "string"
      },
      "connections": {
        "fk_edges": {
          "AT_COMPANY": { "target": "Company", "fk": "issuer_cik" },
          "REPORTED_IN": { "target": "Filing", "fk": "source_accession" }
        }
      }
    },

    "MetricFact": {
      "csv": "processed/metric_fact.csv",
      "pk": "metric_fact_nid",
      "title": "tag",
      "properties": {
        "tag": "string",
        "ddate": "string",
        "qtrs": "int",
        "uom": "string",
        "value": "float",
        "dimensional_context": "string"
      },
      "connections": {
        "fk_edges": {
          "FOR_COMPANY": { "target": "Company", "fk": "issuer_cik" },
          "REPORTED_IN": { "target": "Filing", "fk": "source_accession" }
        }
      }
    },

    "Subsidiary": {
      "csv": "processed/subsidiary.csv",
      "pk": "subsidiary_nid",
      "title": "name",
      "properties": {
        "name": "string",
        "jurisdiction": "string"
      },
      "connections": {
        "fk_edges": {
          "SUBSIDIARY_OF": { "target": "Company", "fk": "parent_cik" },
          "REPORTED_IN": { "target": "Filing", "fk": "source_accession" }
        }
      }
    }
  },

  "compute": [
    {
      "op": "derive",
      "from": "Filing",
      "set": {
        "filing_year": "year(filed_date)",
        "is_annual": "form_type == '10-K'",
        "is_quarterly": "form_type == '10-Q'",
        "is_8k": "form_type == '8-K'"
      }
    },
    {
      "op": "calendar",
      "type": "Day",
      "start": "1994-01-01",
      "end": "2031-12-31",
      "next_edge": "NEXT_DAY",
      "in_month_edge": "IN_MONTH",
      "in_quarter_edge": "IN_QUARTER",
      "links": [
        { "from": "Filing", "date_col": "filed_date", "edge": "FILED_ON" },
        { "from": "InsiderTransaction", "date_col": "transaction_date", "edge": "TRADED_ON" },
        { "from": "Holding", "date_col": "as_of_date", "edge": "HELD_ON" },
        { "from": "CorporateEvent", "date_col": "event_date", "edge": "OCCURRED_ON" }
      ]
    },
    {
      "op": "chain",
      "from": "Filing",
      "group_by": ["cik"],
      "order_by": "filed_date",
      "edge": "NEXT_FILING"
    },
    {
      "op": "chain",
      "from": "InsiderTransaction",
      "group_by": ["person_nid", "issuer_cik"],
      "order_by": "transaction_date",
      "edge": "NEXT_TX"
    },
    {
      "op": "aggregate",
      "from": "InsiderTransaction",
      "group_by": ["person_nid", "issuer_cik"],
      "into": "InsiderActivity",
      "agg": {
        "n_transactions": "count(*)",
        "n_purchases": "sum(if(direction == 'purchase', 1, 0))",
        "n_sales": "sum(if(direction == 'sale', 1, 0))",
        "shares_bought": "sum(if(direction == 'purchase', shares, 0))",
        "shares_sold": "sum(if(direction == 'sale', shares, 0))",
        "buy_value": "sum(if(direction == 'purchase', total_value, 0))",
        "sell_value": "sum(if(direction == 'sale', total_value, 0))",
        "first_transaction": "min(transaction_date)",
        "last_transaction": "max(transaction_date)"
      },
      "edges": [
        { "to": "Person", "fk": "person_nid", "edge": "ACTIVITY_OF" },
        { "to": "Company", "fk": "issuer_cik", "edge": "ACTIVITY_AT" }
      ]
    }
  ]
}
