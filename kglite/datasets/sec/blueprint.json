{
  "compute": [
    {
      "op": "derive",
      "from": "Filing",
      "set": {
        "filing_year": "year(filed_date)",
        "is_form_4": "form_type == '4'",
        "is_annual": "form_type == '10-K'",
        "is_quarterly": "form_type == '10-Q'"
      }
    },
    {
      "op": "filter",
      "from": "MetricFact",
      "where": "tag == 'Revenues' && qtrs == 4",
      "into": "AnnualRevenue"
    },
    {
      "op": "chain",
      "from": "Filing",
      "group_by": ["cik"],
      "order_by": "filed_date",
      "edge": "NEXT_FILING"
    },
    {
      "op": "calendar",
      "start": "2020-01-01",
      "end": "2030-12-31",
      "next_edge": "NEXT_DAY",
      "links": [
        {"from": "Filing",      "date_col": "filed_date",        "edge": "ON_FILED_DATE"},
        {"from": "Transaction", "date_col": "transaction_date",  "edge": "ON_TX_DATE"}
      ]
    },
    {
      "op": "aggregate",
      "from": "Filing",
      "group_by": ["cik", "filing_year"],
      "into": "FilingYear",
      "agg": {
        "n_filings": "count(*)",
        "n_form_4": "sum(if(is_form_4, 1, 0))",
        "n_annual": "sum(if(is_annual, 1, 0))",
        "n_quarterly": "sum(if(is_quarterly, 1, 0))"
      },
      "edges": [
        {"to": "Company", "fk": "cik", "edge": "FILINGS_BY"}
      ]
    },
    {
      "op": "derive",
      "from": "Transaction",
      "set": {
        "total_value": "shares * price_per_share",
        "is_buy":      "transaction_code in ['P', 'A']",
        "is_sell":     "transaction_code in ['S', 'D']"
      }
    },
    {
      "op": "chain",
      "from": "Transaction",
      "group_by": ["person_nid", "issuer_cik"],
      "order_by": "transaction_date",
      "edge": "NEXT_TX"
    },
    {
      "op": "aggregate",
      "from": "Transaction",
      "group_by": ["person_nid", "issuer_cik"],
      "into": "Position",
      "agg": {
        "n_transactions":  "count(*)",
        "first_tx_date":   "min(transaction_date)",
        "last_tx_date":    "max(transaction_date)",
        "current_shares":  "last(shares_owned_after, by=transaction_date)",
        "total_buy_value": "sum(if(is_buy,  total_value, 0))",
        "total_sell_value":"sum(if(is_sell, total_value, 0))"
      },
      "edges": [
        {"to": "Person",  "fk": "person_nid", "edge": "POSITION_OF"},
        {"to": "Company", "fk": "issuer_cik", "edge": "AT_COMPANY"}
      ]
    }
  ],
  "nodes": {
    "SicCode": {
      "csv": "processed/sic.csv",
      "pk": "sic",
      "title": "description",
      "properties": {
        "description": "string"
      }
    },
    "Company": {
      "csv": "processed/company.csv",
      "pk": "cik",
      "title": "name",
      "properties": {
        "name": "string",
        "sic": "string",
        "sic_description": "string",
        "state_of_incorporation": "string",
        "fiscal_year_end": "string",
        "tickers": "string",
        "exchanges": "string",
        "entity_type": "string",
        "former_names": "string"
      },
      "connections": {
        "fk_edges": {
          "IN_INDUSTRY": {
            "target": "SicCode",
            "fk": "sic"
          }
        },
        "junction_edges": {
          "IS_DIRECTOR_OF": {
            "csv": "processed/is_director_of.csv",
            "source_fk": "issuer_cik",
            "target": "Person",
            "target_fk": "person_nid",
            "properties": ["accession_number"]
          },
          "IS_OFFICER_OF": {
            "csv": "processed/is_officer_of.csv",
            "source_fk": "issuer_cik",
            "target": "Person",
            "target_fk": "person_nid",
            "properties": ["officer_title", "accession_number"]
          },
          "IS_BENEFICIAL_OWNER_OF": {
            "csv": "processed/is_beneficial_owner_of.csv",
            "source_fk": "issuer_cik",
            "target": "Person",
            "target_fk": "person_nid",
            "properties": ["accession_number"]
          }
        }
      }
    },
    "Filing": {
      "csv": "processed/filing.csv",
      "pk": "accession_number",
      "title": "primary_document",
      "properties": {
        "form_type": "string",
        "filed_date": "date",
        "report_date": "string",
        "primary_document": "string"
      },
      "connections": {
        "fk_edges": {
          "FILED_BY": {
            "target": "Company",
            "fk": "cik"
          }
        }
      }
    },
    "Subsidiary": {
      "csv": "processed/subsidiary.csv",
      "pk": "subsidiary_nid",
      "title": "name",
      "properties": {
        "name": "string",
        "jurisdiction": "string"
      },
      "connections": {
        "fk_edges": {
          "OF_COMPANY": {
            "target": "Company",
            "fk": "parent_cik"
          }
        }
      }
    },
    "Event": {
      "csv": "processed/event.csv",
      "pk": "event_nid",
      "title": "item_code",
      "properties": {
        "item_code": "string",
        "description": "string"
      },
      "connections": {
        "fk_edges": {
          "OF_FILING": {
            "target": "Filing",
            "fk": "accession_number"
          }
        }
      }
    },
    "Stake": {
      "csv": "processed/stake.csv",
      "pk": "stake_nid",
      "title": "stake_nid",
      "properties": {
        "percent_owned": "float",
        "purpose_text": "string"
      },
      "connections": {
        "fk_edges": {
          "REPORTED_IN_FILING": {
            "target": "Filing",
            "fk": "accession_number"
          }
        }
      }
    },
    "MetricFact": {
      "csv": "processed/metric_fact.csv",
      "pk": "metric_nid",
      "title": "tag",
      "properties": {
        "tag": "string",
        "ddate": "string",
        "qtrs": "int",
        "uom": "string",
        "value": "float"
      },
      "connections": {
        "fk_edges": {
          "REPORTED_IN_FILING": {
            "target": "Filing",
            "fk": "accession_number"
          }
        }
      }
    },
    "InstitutionalManager": {
      "csv": "processed/institutional_manager.csv",
      "pk": "manager_cik",
      "title": "name",
      "properties": {
        "name": "string"
      },
      "connections": {
        "fk_edges": {
          "IS_COMPANY": {
            "target": "Company",
            "fk": "manager_cik"
          }
        },
        "junction_edges": {
          "HOLDS": {
            "csv": "processed/holds.csv",
            "source_fk": "manager_cik",
            "target": "Security",
            "target_fk": "cusip",
            "properties": [
              "value",
              "shares",
              "shares_type",
              "investment_discretion",
              "voting_sole",
              "voting_shared",
              "voting_none",
              "quarter",
              "accession_number"
            ]
          }
        }
      }
    },
    "Security": {
      "csv": "processed/security.csv",
      "pk": "cusip",
      "title": "name",
      "properties": {
        "name": "string",
        "title_of_class": "string"
      }
    },
    "Person": {
      "csv": "processed/person.csv",
      "pk": "person_nid",
      "title": "display_name",
      "properties": {
        "display_name": "string"
      },
      "connections": {
        "junction_edges": {
          "SERVES_ON_BOARD": {
            "csv": "processed/serves_on_board.csv",
            "source_fk": "person_nid",
            "target": "Company",
            "target_fk": "company_cik",
            "properties": ["age", "since_year", "accession_number"],
            "property_types": {
              "age": "int",
              "since_year": "int",
              "accession_number": "string"
            }
          }
        }
      },
      "sub_nodes": {
        "Transaction": {
          "csv": "processed/transaction.csv",
          "pk": "transaction_nid",
          "title": "transaction_code",
          "parent_fk": "person_nid",
          "properties": {
            "security_title": "string",
            "transaction_date": "date",
            "transaction_code": "string",
            "shares": "float",
            "price_per_share": "float",
            "acquired_disposed": "string",
            "shares_owned_after": "float",
            "direct_indirect": "string",
            "is_derivative": "int"
          },
          "connections": {
            "fk_edges": {
              "OF_PERSON": {
                "target": "Person",
                "fk": "person_nid"
              },
              "INVOLVES_ISSUER": {
                "target": "Company",
                "fk": "issuer_cik"
              },
              "REPORTED_IN_FILING": {
                "target": "Filing",
                "fk": "accession_number"
              }
            }
          }
        }
      }
    }
  }
}
