{
  "nodes": {
    "Company": {
      "csv": "processed/company.csv",
      "pk": "cik",
      "title": "name",
      "properties": {
        "name": "string",
        "sic": "string",
        "sic_description": "string",
        "state_of_incorporation": "string",
        "fiscal_year_end": "string",
        "tickers": "string",
        "exchanges": "string",
        "entity_type": "string",
        "former_names": "string"
      },
      "connections": {
        "junction_edges": {
          "HAS_INSIDER": {
            "csv": "processed/has_insider.csv",
            "source_fk": "issuer_cik",
            "target": "Person",
            "target_fk": "person_nid",
            "properties": [
              "is_director",
              "is_officer",
              "is_ten_percent_owner",
              "is_other",
              "officer_title"
            ]
          }
        }
      }
    },
    "Filing": {
      "csv": "processed/filing.csv",
      "pk": "accession_number",
      "title": "primary_document",
      "properties": {
        "form_type": "string",
        "filed_date": "date",
        "report_date": "string",
        "primary_document": "string"
      },
      "connections": {
        "fk_edges": {
          "FILED_BY": {
            "target": "Company",
            "fk": "cik"
          }
        }
      }
    },
    "Subsidiary": {
      "csv": "processed/subsidiary.csv",
      "pk": "subsidiary_nid",
      "title": "name",
      "properties": {
        "name": "string",
        "jurisdiction": "string"
      },
      "connections": {
        "fk_edges": {
          "OF_COMPANY": {
            "target": "Company",
            "fk": "parent_cik"
          }
        }
      }
    },
    "Event": {
      "csv": "processed/event.csv",
      "pk": "event_nid",
      "title": "item_code",
      "properties": {
        "item_code": "string",
        "description": "string"
      },
      "connections": {
        "fk_edges": {
          "OF_FILING": {
            "target": "Filing",
            "fk": "accession_number"
          }
        }
      }
    },
    "MetricFact": {
      "csv": "processed/metric_fact.csv",
      "pk": "metric_nid",
      "title": "tag",
      "properties": {
        "tag": "string",
        "ddate": "string",
        "qtrs": "int",
        "uom": "string",
        "value": "float"
      },
      "connections": {
        "fk_edges": {
          "REPORTED_IN_FILING": {
            "target": "Filing",
            "fk": "accession_number"
          }
        }
      }
    },
    "InstitutionalManager": {
      "csv": "processed/institutional_manager.csv",
      "pk": "manager_cik",
      "title": "name",
      "properties": {
        "name": "string"
      },
      "connections": {
        "junction_edges": {
          "HOLDS": {
            "csv": "processed/holds.csv",
            "source_fk": "manager_cik",
            "target": "Security",
            "target_fk": "cusip",
            "properties": [
              "value",
              "shares",
              "shares_type",
              "investment_discretion",
              "voting_sole",
              "voting_shared",
              "voting_none",
              "quarter",
              "accession_number"
            ]
          }
        }
      }
    },
    "Security": {
      "csv": "processed/security.csv",
      "pk": "cusip",
      "title": "name",
      "properties": {
        "name": "string",
        "title_of_class": "string"
      }
    },
    "Person": {
      "csv": "processed/person.csv",
      "pk": "person_nid",
      "title": "display_name",
      "properties": {
        "display_name": "string"
      },
      "sub_nodes": {
        "Transaction": {
          "csv": "processed/transaction.csv",
          "pk": "transaction_nid",
          "title": "transaction_code",
          "parent_fk": "person_nid",
          "properties": {
            "security_title": "string",
            "transaction_date": "date",
            "transaction_code": "string",
            "shares": "float",
            "price_per_share": "float",
            "acquired_disposed": "string",
            "shares_owned_after": "float",
            "direct_indirect": "string",
            "is_derivative": "int"
          },
          "connections": {
            "fk_edges": {
              "OF_PERSON": {
                "target": "Person",
                "fk": "person_nid"
              },
              "INVOLVES_ISSUER": {
                "target": "Company",
                "fk": "issuer_cik"
              },
              "REPORTED_IN_FILING": {
                "target": "Filing",
                "fk": "accession_number"
              }
            }
          }
        }
      }
    }
  }
}
