  "compute": [
    {
      "op": "derive",
      "from": "Filing",
      "set": {
        "filing_year": "year(filed_date)",
        "is_annual": "form_type == '10-K'",
        "is_quarterly": "form_type == '10-Q'",
        "is_8k": "form_type == '8-K'"
      }
    },
    {
      "op": "calendar",
      "type": "Day",
      "start": "1994-01-01",
      "end": "2031-12-31",
      "next_edge": "NEXT_DAY",
      "in_month_edge": "IN_MONTH",
      "in_quarter_edge": "IN_QUARTER",
      "links": [
        { "from": "Filing", "date_col": "filed_date", "edge": "FILED_ON" },
        { "from": "InsiderTransaction", "date_col": "transaction_date", "edge": "TRADED_ON" },
        { "from": "Holding", "date_col": "as_of_date", "edge": "HELD_ON" },
        { "from": "CorporateEvent", "date_col": "event_date", "edge": "OCCURRED_ON" }
      ]
    },
    {
      "op": "chain",
      "from": "Filing",
      "group_by": ["cik"],
      "order_by": "filed_date",
      "edge": "NEXT_FILING"
    },
    {
      "op": "chain",
      "from": "InsiderTransaction",
      "group_by": ["person_nid", "issuer_cik"],
      "order_by": "transaction_date",
      "edge": "NEXT_TX"
    },
    {
      "op": "aggregate",
      "from": "InsiderTransaction",
      "group_by": ["person_nid", "issuer_cik"],
      "into": "InsiderActivity",
      "agg": {
        "n_transactions": "count(*)",
        "n_purchases": "sum(if(direction == 'purchase', 1, 0))",
        "n_sales": "sum(if(direction == 'sale', 1, 0))",
        "shares_bought": "sum(if(direction == 'purchase', shares, 0))",
        "shares_sold": "sum(if(direction == 'sale', shares, 0))",
        "buy_value": "sum(if(direction == 'purchase', total_value, 0))",
        "sell_value": "sum(if(direction == 'sale', total_value, 0))",
        "first_transaction": "min(transaction_date)",
        "last_transaction": "max(transaction_date)"
      },
      "edges": [
        { "to": "Person", "fk": "person_nid", "edge": "ACTIVITY_OF" },
        { "to": "Company", "fk": "issuer_cik", "edge": "ACTIVITY_AT" }
      ]
    }
  ]
}
